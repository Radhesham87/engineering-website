# ---- Backend environment ----
# Local dev uses SQLite by default. For production set a Postgres URL:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./dev.db

# CHANGE THIS to a long random string in production
JWT_SECRET=CHANGE_ME_super_secret_key_min_32_chars_long_please
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default admin (change before deploying!)
ADMIN_EMAIL=admin@engpredictor.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Administrator

# Comma-separated allowed frontend origins
FRONTEND_ORIGINS=http://localhost:3000

# Unified engineering cutoff dataset (MH-CET + JEE-Main)
DATASET_PATH=data/engineering_cutoffs.csv.gz
